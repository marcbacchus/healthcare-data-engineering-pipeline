# Snowflake connection — use the LOADER role provisioned in Phase 1
# Account format: orgname-accountname  (find in Snowflake: Admin > Accounts)
SNOWFLAKE_ACCOUNT=orgname-accountname
SNOWFLAKE_USER=your_snowflake_user
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ROLE=LOADER
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=HEALTHCARE_RAW
SNOWFLAKE_SCHEMA=RAW

# CMS Open Payments 2023 General Payments
# Find the dataset ID: go to data.cms.gov, search "Open Payments General Payment Data",
# open the 2023 dataset, click "API" — the resource ID is the last segment of the endpoint URL
CMS_DATASET_ID=
CMS_ROW_LIMIT=100000

# FDA FAERS quarter to load (format: YYqN, e.g. 24q4 = Q4 2024)
FAERS_QUARTER=24q4
